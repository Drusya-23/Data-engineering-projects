						"referenceName": "ls_adls",
						"type": "LinkedServiceReference"
					},
					"name": "customerserviceinteractions"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "ls_sql",
						"type": "LinkedServiceReference"
					},
					"name": "sink1loyaltyaccounts"
				},
				{
					"linkedService": {
						"referenceName": "ls_sql",
						"type": "LinkedServiceReference"
					},
					"name": "sink2loyaltytransactions"
				},
				{
					"linkedService": {
						"referenceName": "ls_sql",
						"type": "LinkedServiceReference"
					},
					"name": "sinkonlinetransactions"
				},
				{
					"linkedService": {
						"referenceName": "ls_sql",
						"type": "LinkedServiceReference"
					},
					"name": "sinstoretransactions"
				},
				{
					"linkedService": {
						"referenceName": "ls_sql",
						"type": "LinkedServiceReference"
					},
					"name": "customerserviceinteractionss"
				}
			],
			"transformations": [
				{
					"name": "removenullsla"
				},
				{
					"name": "removeduplicatesla"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "removenullslt"
				},
				{
					"name": "removeduplicateslt"
				},
				{
					"name": "alterRow2"
				},
				{
					"name": "removenullsot"
				},
				{
					"name": "removeduplicatesot"
				},
				{
					"name": "alterRow3"
				},
				{
					"name": "removenullsit"
				},
				{
					"name": "removedulicatesit"
				},
				{
					"name": "alterRow4"
				},
				{
					"name": "removenullsci"
				},
				{
					"name": "removeduplicatesci"
				},
				{
					"name": "alterRow5"
				}
			],
			"scriptLines": [
				"source(output(",
				"          LoyaltyID as integer,",
				"          CustomerID as integer,",
				"          PointsEarned as integer,",
				"          TierLevel as string,",
				"          JoinDate as date",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'project3',",
				"     folderPath: 'bronze',",
				"     fileName: 'LoyaltyAccounts.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> loyaltyaccounts",
				"source(output(",
				"          LoyaltyID as integer,",
				"          DateTime as timestamp,",
				"          PointsChange as integer,",
				"          Reason as string",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'project3',",
				"     folderPath: 'bronze',",
				"     fileName: 'LoyaltyTransactions.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> loyaltytransactions",
				"source(output(",
				"          OrderID as integer,",
				"          CustomerID as integer,",
				"          ProductID as integer,",
				"          DateTime as timestamp,",
				"          PaymentMethod as string,",
				"          Amount as double,",
				"          Status as string",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'project3',",
				"     folderPath: 'bronze',",
				"     fileName: 'OnlineTransactions.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> onlinetransactions",
				"source(output(",
				"          TransactionID as integer,",
				"          CustomerID as integer,",
				"          StoreID as integer,",
				"          DateTime as timestamp,",
				"          Amount as double,",
				"          PaymentMethod as string",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'project3',",
				"     folderPath: 'bronze',",
				"     fileName: 'InStoreTransactions.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> instoretransactions",
				"source(output(",
				"          InteractionID as integer,",
				"          CustomerID as integer,",
				"          DateTime as timestamp,",
				"          AgentID as integer,",
				"          IssueType as string,",
				"          ResolutionStatus as string",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'project3',",
				"     folderPath: 'bronze',",
				"     fileName: 'CustomerServiceInteractions.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> customerserviceinteractions",
				"loyaltyaccounts filter(!isNull(LoyaltyID)) ~> removenullsla",
				"removenullsla aggregate(groupBy(LoyaltyID),",
				"     CustomerID = first(CustomerID),",
				"          PointsEarned = first(PointsEarned),",
				"          TierLevel = first(TierLevel),",
				"          JoinDate = first(JoinDate)) ~> removeduplicatesla",
				"removeduplicatesla alterRow(upsertIf(1==1)) ~> alterRow1",
				"loyaltytransactions filter(!isNull(LoyaltyID) && !isNull(DateTime)) ~> removenullslt",
				"removenullslt aggregate(groupBy(LoyaltyID,",
				"          DateTime),",
				"     PointsChange = first(PointsChange),",
				"          Reason = first(PointsChange)) ~> removeduplicateslt",
				"removeduplicateslt alterRow(upsertIf(1==1)) ~> alterRow2",
				"onlinetransactions filter(!isNull(OrderID) && !isNull(CustomerID) && !isNull(ProductID)) ~> removenullsot",
				"removenullsot aggregate(groupBy(OrderID),",
				"     CustomerID = first(CustomerID),",
				"          ProductID = first(ProductID),",
				"          DateTime = first(DateTime),",
				"          PaymentMethod = first(PaymentMethod),",
				"          Amount = first(Amount),",
				"          Status = first(Status)) ~> removeduplicatesot",
				"removeduplicatesot alterRow(upsertIf(1==1)) ~> alterRow3",
				"instoretransactions filter(!isNull(TransactionID) && !isNull(CustomerID) && !isNull(StoreID)) ~> removenullsit",
				"removenullsit aggregate(groupBy(TransactionID),",
				"     CustomerID = first(CustomerID),",
				"          StoreID = first(StoreID),",
				"          DateTime = first(DateTime),",
				"          Amount = first(Amount),",
				"          PaymentMethod = first(PaymentMethod)) ~> removedulicatesit",
				"removedulicatesit alterRow(upsertIf(1==1)) ~> alterRow4",
				"customerserviceinteractions filter(!isNull(InteractionID) && !isNull(CustomerID) && !isNull(AgentID)) ~> removenullsci",
				"removenullsci aggregate(groupBy(InteractionID),",
				"     CustomerID = first(CustomerID),",
				"          DateTime = first(DateTime),",
				"          AgentID = first(AgentID),",
				"          IssueType = first(IssueType),",
				"          ResolutionStatus = first(ResolutionStatus)) ~> removeduplicatesci",
				"removeduplicatesci alterRow(upsertIf(1==1)) ~> alterRow5",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'LoyaltyAccounts',",
				"     insertable: false,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: true,",
				"     keys:['LoyaltyID'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          LoyaltyID,",
				"          CustomerID,",
				"          PointsEarned,",
				"          TierLevel,",
				"          JoinDate",
				"     )) ~> sink1loyaltyaccounts",
				"alterRow2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'LoyaltyTransactions',",
				"     insertable: false,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: true,",
				"     keys:['LoyaltyID','DateTime'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          LoyaltyID,",
				"          DateTime,",
				"          PointsChange,",
				"          Reason",
				"     )) ~> sink2loyaltytransactions",
				"alterRow3 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'OnlineTransactions',",
				"     insertable: false,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: true,",
				"     keys:['OrderID'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          OrderID,",
				"          CustomerID,",
				"          ProductID,",
				"          DateTime,",
				"          PaymentMethod,",
				"          Amount,",
				"          Status",
				"     )) ~> sinkonlinetransactions",
				"alterRow4 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'InStoreTransactions',",
				"     insertable: false,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: true,",
				"     keys:['TransactionID'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          TransactionID,",
				"          CustomerID,",
				"          StoreID,",
				"          DateTime,",
				"          Amount,",
				"          PaymentMethod",
				"     )) ~> sinstoretransactions",
				"alterRow5 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'CustomerServiceInteractions',",
				"     insertable: false,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: true,",
				"     keys:['InteractionID'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          InteractionID,",
				"          CustomerID,",
				"          DateTime,",
				"          AgentID,",
				"          IssueType,",
				"          ResolutionStatus",
				"     )) ~> customerserviceinteractionss"
			]
		}
	}
}