{
	"name": "Dataflow3",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "ls_adls",
						"type": "LinkedServiceReference"
					},
					"name": "CUSTOMER"
				},
				{
					"linkedService": {
						"referenceName": "ls_adls",
						"type": "LinkedServiceReference"
					},
					"name": "PRODUCT"
				},
				{
					"linkedService": {
						"referenceName": "ls_adls",
						"type": "LinkedServiceReference"
					},
					"name": "STORES"
				},
				{
					"linkedService": {
						"referenceName": "ls_adls",
						"type": "LinkedServiceReference"
					},
					"name": "AGENTS"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "ls_sql",
						"type": "LinkedServiceReference"
					},
					"name": "CUSTOMERSSINK1"
				},
				{
					"linkedService": {
						"referenceName": "ls_sql",
						"type": "LinkedServiceReference"
					},
					"name": "PRODUCTSSINK2"
				},
				{
					"linkedService": {
						"referenceName": "ls_sql",
						"type": "LinkedServiceReference"
					},
					"name": "sink3stores"
				},
				{
					"linkedService": {
						"referenceName": "ls_sql",
						"type": "LinkedServiceReference"
					},
					"name": "AGENTSSINK4"
				}
			],
			"transformations": [
				{
					"name": "REMOVENULLSC"
				},
				{
					"name": "REMOVEDUPLICATESC"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "REMOVENULLSP"
				},
				{
					"name": "REMOVEDUPLICATESP"
				},
				{
					"name": "alterRow2"
				},
				{
					"name": "fREMOVENULLSS"
				},
				{
					"name": "REMOVEDUPLICATESS"
				},
				{
					"name": "alterRow3"
				},
				{
					"name": "REMOVENULLSA"
				},
				{
					"name": "REMOVEDUPLICATESA"
				},
				{
					"name": "alterRow4"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerID as integer,",
				"          Name as string,",
				"          Email as string,",
				"          Address as string",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'project3',",
				"     folderPath: 'bronze',",
				"     fileName: 'Customers (1).csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> CUSTOMER",
				"source(output(",
				"          ProductID as integer,",
				"          Name as string,",
				"          Category as string,",
				"          Price as double",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'project3',",
				"     folderPath: 'bronze',",
				"     fileName: 'Products.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> PRODUCT",
				"source(output(",
				"          StoreID as integer,",
				"          Location as string,",
				"          Manager as string,",
				"          OpenHours as string",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'project3',",
				"     folderPath: 'bronze',",
				"     fileName: 'Stores.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> STORES",
				"source(output(",
				"          AgentID as integer,",
				"          Name as string,",
				"          Department as string,",
				"          Shift as string",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'project3',",
				"     folderPath: 'bronze',",
				"     fileName: 'Agents.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> AGENTS",
				"CUSTOMER filter(!isNull(CustomerID)) ~> REMOVENULLSC",
				"REMOVENULLSC aggregate(groupBy(CustomerID),",
				"     Name = first(Name),",
				"          Email = first(Email),",
				"          Address = first(Address)) ~> REMOVEDUPLICATESC",
				"REMOVEDUPLICATESC alterRow(upsertIf(1==1)) ~> alterRow1",
				"PRODUCT filter(!isNull(ProductID)) ~> REMOVENULLSP",
				"REMOVENULLSP aggregate(groupBy(ProductID),",
				"     Name = first(Name),",
				"          Category = first(Category),",
				"          Price = first(Price)) ~> REMOVEDUPLICATESP",
				"REMOVEDUPLICATESP alterRow(upsertIf(1==1)) ~> alterRow2",
				"STORES filter(!isNull(StoreID)) ~> fREMOVENULLSS",
				"fREMOVENULLSS aggregate(groupBy(StoreID),",
				"     Location = first(Location),",
				"          Manager = first(Manager),",
				"          OpenHours = first(OpenHours)) ~> REMOVEDUPLICATESS",
				"REMOVEDUPLICATESS alterRow(upsertIf(1==1)) ~> alterRow3",
				"AGENTS filter(!isNull(AgentID)) ~> REMOVENULLSA",
				"REMOVENULLSA aggregate(groupBy(AgentID),",
				"     Name = first(Name),",
				"          Department = first(Department),",
				"          Shift = first(Shift)) ~> REMOVEDUPLICATESA",
				"REMOVEDUPLICATESA alterRow(upsertIf(1==1)) ~> alterRow4",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'Customers',",
				"     insertable: false,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: true,",
				"     keys:['CustomerID'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CustomerID,",
				"          Name,",
				"          Email,",
				"          Address",
				"     )) ~> CUSTOMERSSINK1",
				"alterRow2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'Products',",
				"     insertable: false,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: true,",
				"     keys:['ProductID'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          ProductID,",
				"          Name,",
				"          Category,",
				"          Price",
				"     )) ~> PRODUCTSSINK2",
				"alterRow3 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'Stores',",
				"     insertable: false,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: true,",
				"     keys:['StoreID'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          StoreID,",
				"          Location,",
				"          Manager,",
				"          OpenHours",
				"     )) ~> sink3stores",
				"alterRow4 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'Agents',",
				"     insertable: false,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: true,",
				"     keys:['AgentID'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          AgentID,",
				"          Name,",
				"          Department,",
				"          Shift",
				"     )) ~> AGENTSSINK4"
			]
		}
	}
}