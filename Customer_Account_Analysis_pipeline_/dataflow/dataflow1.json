			"transformations": [
				{
					"name": "filter"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "aggregate1"
				},
				{
					"name": "filter1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "aggregate2"
				},
				{
					"name": "filter2"
				},
				{
					"name": "aggregate3"
				},
				{
